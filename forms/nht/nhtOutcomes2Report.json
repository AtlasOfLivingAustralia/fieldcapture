{
  "name": "NHT Outcomes 2 Report",
  "type": "Report",
  "sections": [
    {
      "name": "NHT Outcomes 2 Report",
      "optionalQuestionText": null,
      "optional": false,
      "collapsedByDefault": false,
      "templateName": "nht_outcomes2_report",
      "template": {
        "modelName": "NHT Outcomes 2 Report",
        "dataModel": [
          {
            "dataType": "text",
            "name": "primaryOutcomeDescription"
          },
          {
            "dataType": "text",
            "name": "primaryOutcomeInvestmentPriority"
          },
          {
            "dataType": "list",
            "name": "programSecondaryOutcomes",
            "allowRowDelete": "false",
            "columns": [
              {
                "dataType": "text",
                "name": "secondaryOutcomeStatement"
              },
              {
                "dataType": "text",
                "name": "secondaryOutcomeInvestmentPriorities"
              }
            ]
          },
          {
            "dataType": "list",
            "name": "projectOutcomes",
            "allowRowDelete": "false",
            "columns": [
              {
                "dataType": "text",
                "name": "code"
              },
              {
                "dataType": "text",
                "name": "outcomeStatement",
                "validate": "required"
              },
              {
                "dataType": "text",
                "name": "outcomeInvestmentPriorities",
                "validate": "required"
              },
              {
                "dataType": "text",
                "name": "relatedProgramOutcome",
                "validate": "required"
              },
              {
                "dataType": "text",
                "name": "effectivePestControlPercentage"
              },
              {
                "dataType": "text",
                "name": "pestCompetitorSpeciesControlled"
              },
              {
                "dataType": "stringList",
                "name": "csapOutcomes",
                "constraints": [
                  "Farmers accept and value CSSA practices (Attitude/Culture)",
                  "Farmers are accessing advice and support",
                  "Farmers are accessing demonstrations of innovative and effective practices",
                  "Farmers are accessing relevant information resources and products",
                  "Farmers are adopting innovative tools, technologies or practices",
                  "Farmers are aware of CSSA practices, and their value and opportunities",
                  "Farmers are connecting to peer networks",
                  "Farmers are trialling and/or adopting CSSA practices",
                  "Farmers have the skills to adopt CSSA practices",
                  "Farmers understand how and why to adopt CSSA practices (Knowledge)",
                  "Farmers are demonstrating sustainability credentials and traceability",
                  "Farmers are implementing sustainability frameworks"
                ]
              },
              {
                "dataType": "text",
                "name": "projectAchievementAgainstOutcome",
                "validate": "required,maxSize[2500]",
                "description": "Where applicable, refer to the 'Key Threat(s)' and 'Monitoring Methodology' sections of the MERI Plan and Project Services to show how your activities support the stated outcome and align with the identified investment priority."
              },
              {
                "dataType": "text",
                "name": "programLogicAssumptions",
                "validate": "required,maxSize[1500]",
                "description": "This question asks you to reflect on how well the assumptions outlined in the Project Logic - whether previously tested through evidence or still unverified—contributed to achieving the intended outcomes. Consider both the relevance and accuracy of these assumptions in practice."
              },
              {
                "dataType": "stringList",
                "name": "projectOutcomeAchievementDegree",
                "validate": "required",
                "description": "<ul><li>Fully Achieved = Outcome measure achieved,</li><li>Mostly Achieved = half or more of the outcome measure achieved,</li><li>Partially Achieved = Less than half of the outcome measure achieved,</li><li>Not Achieved = Outcome measure not achieved.</li></ul>",
                "constraints": [
                  "Fully achieved",
                  "Mostly achieved",
                  "Partially achieved",
                  "Not achieved"
                ]
              }
            ]
          },
          {
            "dataType": "stringList",
            "name": "overallOutcomesAchievement",
            "validate": "required",
            "constraints": [
              "Fully achieved",
              "Mostly achieved",
              "Partially achieved",
              "Not achieved"
            ],
            "description": "<ul><li>Fully Achieved = all MERI plan outcome statements were met as planned,</li> <li> Mostly Achieved = at least half of all MERI plan outcome statements were met as planned,</li> <li> Partially Achieved = less than half of all MERI plan outcome statements were met as planned,</li> <li> Not Achieved = none of the MERI plan outcome statements were met as planned</li></ul>"
          },
          {
            "dataType": "text",
            "name": "additionalAchievementComments",
            "validate": "maxSize[1500]"
          },
          {
            "dataType": "text",
            "description": "",
            "name": "keq1",
            "validate": "required",
            "constraints": [
              "Significantly",
              "Satisfactorily",
              "Partially",
              "Not at all"
            ]
          },
          {
            "dataType": "text",
            "name": "keq1How",
            "validate": "required,maxSize[1500]"
          },
          {
            "dataType": "text",
            "description": "",
            "name": "keq2",
            "validate": "required",
            "constraints": [
              "Yes",
              "No"
            ]
          },
          {
            "dataType": "text",
            "name": "keq2What",
            "validate": "required,maxSize[1500]",
            "behaviour": [
              {
                "type": "enable_and_clear",
                "condition": "\"No\" == keq2"
              }
            ]
          },
          {
            "dataType": "stringList",
            "description": "",
            "name": "keq3",
            "validate": "required",
            "constraints": [
              "Stakeholder Engagement",
              "Community involvement",
              "Partnerships with local groups",
              "Collaboration with Indigenous groups",
              "Funding and Resources",
              "In-kind contributions",
              "Governance and accountability with well-defined roles and responsibilities",
              "Regulatory or policy requirements",
              "Project planning",
              "Conservation advice",
              "Management plans and strategies",
              "Regular Monitoring and evaluation",
              "Weather conditions",
              "Time and capacity",
              "Resource use or economic priorities",
              "Data and knowledge",
              "IT infrastructure",
              "Site access/location",
              "Access to expertise and skilled personnel",
              "Other (enable mandatory free text to define if ‘other’ selected. ‘Other’ could also be used to provide additional context for the options above.)"
            ]
          },
          {
            "dataType": "text",
            "name": "keq3Other",
            "validate": "required,maxSize[1500]",
            "behaviour": [
              {
                "type": "enable_and_clear",
                "condition": "\"Other (enable mandatory free text to define if ‘other’ selected. ‘Other’ could also be used to provide additional context for the options above.)\" in keq3"
              }
            ]
          },
          {
            "dataType": "stringList",
            "description": "",
            "name": "keq4",
            "validate": "required",
            "constraints": [
              "Stakeholder Engagement",
              "Community involvement",
              "Partnerships with local groups",
              "Collaboration with Indigenous groups",
              "Funding and Resources",
              "In-kind contributions not realised",
              "Governance and accountability with well-defined roles and responsibilities",
              "Regulatory or policy requirements",
              "Project planning",
              "Conservation advice",
              "Management plans and strategies",
              "Regular monitoring and evaluation",
              "Natural disasters or extreme weather events",
              "Disease/Pandemic",
              "Time and capacity constraints",
              "Resource use or economic priorities",
              "Data and knowledge",
              "IT infrastructure",
              "Site Access/Location",
              "Access to expertise and skilled personnel",
              "Other (enable mandatory free text to define if ‘other’ selected. ‘Other’ could also be used to provide additional context for the options above.)"
            ]
          },
          {
            "dataType": "text",
            "name": "keq4Other",
            "validate": "required,maxSize[1500]",
            "behaviour": [
              {
                "type": "enable_and_clear",
                "condition": "\"Other (enable mandatory free text to define if ‘other’ selected. ‘Other’ could also be used to provide additional context for the options above.)\" in keq4"
              }
            ]
          },
          {
            "dataType": "text",
            "description": "",
            "name": "keq5",
            "validate": "required",
            "constraints": [
              "Yes",
              "No"
            ]
          },
          {
            "dataType": "text",
            "name": "keq5Why",
            "validate": "required,maxSize[1500]"
          },
          {
            "dataType": "text",
            "description": "",
            "name": "keq6",
            "validate": "required",
            "constraints": [
              "Yes",
              "No",
              "N/A"
            ]
          },
          {
            "dataType": "text",
            "name": "keq6How",
            "validate": "required,maxSize[1500]",
            "behaviour": [
              {
                "type": "enable_and_clear",
                "condition": "\"Yes\" == keq6 or \"No\" == keq6"
              }
            ]
          },
          {
            "dataType": "text",
            "description": "",
            "name": "keq7",
            "validate": "required",
            "constraints": [
              "Yes",
              "No"
            ]
          },
          {
            "dataType": "text",
            "name": "keq7What",
            "validate": "required,maxSize[1500]",
            "behaviour": [
              {
                "type": "enable_and_clear",
                "condition": "\"Yes\" == keq7"
              }
            ]
          },
          {
            "dataType": "text",
            "description": "",
            "name": "keq8",
            "validate": "required",
            "constraints": [
              "Yes",
              "No"
            ]
          },
          {
            "dataType": "text",
            "name": "keq8Specify",
            "validate": "required,maxSize[1500]",
            "behaviour": [
              {
                "type": "enable_and_clear",
                "condition": "\"Yes\" == keq8"
              }
            ]
          },
          {
            "dataType": "text",
            "description": "",
            "name": "keq9",
            "validate": "required",
            "constraints": [
              "Significantly",
              "Satisfactorily",
              "Partially",
              "Not at all",
              "N/A"
            ]
          },
          {
            "dataType": "text",
            "name": "keq9How",
            "validate": "required,maxSize[1500]"
          },
          {
            "dataType": "text",
            "name": "keq10",
            "validate": "required,maxSize[1500]"
          }
        ],
        "viewModel": [
          {
            "items": [
              {
                "source": "A final outcomes report (designed for RDP Panel projects) to assess a projects short or medium term outcomes (dependant on duration) at project finalisation.",
                "type": "literal"
              }
            ],
            "type": "row"
          },
          {
            "items": [
              {
                "source": "<h4>1. PROJECT OUTCOMES</h4>",
                "type": "literal"
              }
            ],
            "type": "row"
          },
          {
            "items": [
              {
                "source": "<h5>Program Outcome</h5>",
                "type": "literal"
              }
            ],
            "type": "row"
          },
          {
            "type": "table",
            "columns": [
              {
                "type": "readonlyText",
                "readonly": true,
                "source": "primaryOutcomeDescription",
                "title": "Primary Outcome",
                "rows": 5,
                "width": "50%"
              },
              {
                "type": "readonlyText",
                "readonly": true,
                "source": "primaryOutcomeInvestmentPriority",
                "title": "Primary Investment Priority",
                "rows": 5,
                "width": "50%"
              }
            ]
          },
          {
            "items": [
              {
                "source": "<h5>Additional Benefits</h5>",
                "type": "literal"
              }
            ],
            "type": "row"
          },
          {
            "source": "programSecondaryOutcomes",
            "title": "",
            "type": "table",
            "disableTableUpload": true,
            "columns": [
              {
                "type": "textarea",
                "readonly": true,
                "source": "secondaryOutcomeStatement",
                "title": "Additional Outcome/s",
                "rows": 5,
                "width": "50%"
              },
              {
                "type": "textarea",
                "readonly": true,
                "source": "secondaryOutcomeInvestmentPriorities",
                "title": "Additional Investment Priorities",
                "rows": 5,
                "width": "50%"
              }
            ]
          },
          {
            "items": [
              {
                "source": "<b>1.1 To what extent did you achieve the MERI plan outcomes for your project?</b><b style=\"color:red\">*</b><br>Reflecting on each of the project outcome statements in your MERI plan, please specify what your project achieved over the reporting period, as well as the degree to which the planned outcome(s) for this period were or were not achieved.",
                "type": "literal"
              }
            ],
            "type": "row"
          },
          {
            "source": "projectOutcomes",
            "title": "",
            "type": "table",
            "disableTableUpload": true,
            "columns": [
              {
                "source": "code",
                "type": "readonlyText",
                "title": "Outcome No."
              },
              {
                "type": "readonlyText",
                "readonly": true,
                "source": "outcomeStatement",
                "title": "Outcome Statement",
                "rows": 5,
                "width": "10%"
              },
              {
                "type": "readonlyText",
                "readonly": true,
                "source": "outcomeInvestmentPriorities",
                "title": "Investment Priority",
                "rows": 5,
                "width": "10%"
              },
              {
                "type": "readonlyText",
                "readonly": true,
                "source": "relatedProgramOutcome",
                "title": "Related Program Outcome",
                "rows": 5,
                "width": "10%"
              },
              {
                "width": "20%",
                "type": "col",
                "title": "Supplementary Questions",
                "helpText": "Additional questions to support outcomes at the program level. If blank please disregard.",
                "items": [
                  {
                    "type": "row",
                    "behaviour": [
                      {
                        "type": "if_expression",
                        "condition": "relatedProgramOutcome == \"1.  Species and Landscapes (Short term): Managing Threats - Pest predator and competitor species have been controlled or are under active, long-term control programs\" or relatedProgramOutcome == \"2. World Heritage Protection (Short term): Managing threats - Pest predator and competitor species have been controlled\" or relatedProgramOutcome == \"3. Ramsar Wetland Protection (Short term): Managing Threats - Pest predator and competitor species have been controlled \""
                      }
                    ],
                    "items": [
                      {
                        "type": "col",
                        "items": [
                          {
                            "type": "text",
                            "width": "10%",
                            "source": "effectivePestControlPercentage",
                            "preLabel": "Q1. Over the project area, what is the reduction in pest/competitor species that were effectively controlled (0-100) %",
                            "rows": 4,
                            "fullWidthLabelAbove": true
                          },
                          {
                            "type": "textarea",
                            "source": "pestCompetitorSpeciesControlled",
                            "preLabel": "Q2. What pest/competitor species have been controlled?",
                            "rows": 4,
                            "fullWidthLabelAbove": true
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "row",
                    "behaviour": [
                      {
                        "type": "if_expression",
                        "condition": "relatedProgramOutcome == \"1. The agriculture sector is adopting practices to reduce emissions and build resilience to climate change (Medium term)\" or relatedProgramOutcome == \"1. The agriculture sector is supported to harness carbon and biodiversity incentives and implement industry sustainability frameworks (Medium term)\" or relatedProgramOutcome == \"1. Farmers are supported to drive agricultural growth, while adopting sustainable natural resource management practices that protect and conserve natural capital and biodiversity (Medium term)\" or relatedProgramOutcome == \"1. The agriculture sector is adopting practices to reduce emissions and build resilience to climate change (Short term)\" or relatedProgramOutcome == \"1. The agriculture sector is supported to harness carbon and biodiversity incentives and implement industry sustainability frameworks (Short term)\" or relatedProgramOutcome == \"1. Farmers are supported to drive agricultural growth, while adopting sustainable natural resource management practices that protect and conserve natural capital and biodiversity (Short term)\""
                      }
                    ],
                    "items": [
                      {
                        "type": "col",
                        "items": [
                          {
                            "type": "select2Many",
                            "source": "csapOutcomes",
                            "preLabel": "Which CSAP outcomes are supported by this project outcome?"
                          }
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "type": "textarea",
                "source": "projectAchievementAgainstOutcome",
                "title": "What did the project achieve against this outcome statement?",
                "rows": 5,
                "width": "20%"
              },
              {
                "type": "textarea",
                "source": "programLogicAssumptions",
                "title": "To what extent were the Program Logic assumptions, both tested and untested, accurate in supporting the outcome statement?",
                "rows": 5,
                "width": "20%"
              },
              {
                "type": "selectOne",
                "source": "projectOutcomeAchievementDegree",
                "title": "To what degree was the project outcome achieved?",
                "rows": 5,
                "width": "20%"
              }
            ]
          },
          {
            "items": [
              {
                "source": "overallOutcomesAchievement",
                "preLabel": "1.2 Considered collectively (based on previous responses in table 1.1), to what extent were the MERI plan outcomes achieved for your project?",
                "type": "selectOne"
              }
            ],
            "type": "row"
          },
          {
            "type": "row",
            "items": [
              {
                "source": "additionalAchievementComments",
                "type": "textarea",
                "rows": 5,
                "preLabel": "If you have any other comments about the achievements against outcomes outlined in your MERI plan, provide details here."
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "computed": null,
                "type": "literal",
                "source": "<h3>Key Evaluation Questions</h3>"
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "preLabel": "KEQ1. To what extent has the project increased knowledge of best practice NRM for the investment priority(ies)?",
                "type": "selectOne",
                "rows": 5,
                "source": "keq1"
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "preLabel": "KEQ1.1 How?",
                "type": "textarea",
                "rows": 5,
                "source": "keq1How"
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "preLabel": "KEQ2. Were the methods/strategies used the best way to achieve/maximise project outcomes?",
                "type": "selectOne",
                "rows": 5,
                "source": "keq2"
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "preLabel": "KEQ2.1 If no, what other methods/strategies might have been more effective?",
                "type": "textarea",
                "rows": 5,
                "source": "keq2What"
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "preLabel": "KEQ3. What factors contributed (enablers) to the achievement of outcomes for the investment priority(ies)?",
                "type": "select2Many",
                "rows": 5,
                "source": "keq3"
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "preLabel": "Please specify the other enablers",
                "type": "textarea",
                "rows": 2,
                "source": "keq3Other"
              }
            ],
            "behaviour": [
              {
                "type": "if_expression",
                "condition": "\"Other (enable mandatory free text to define if ‘other’ selected. ‘Other’ could also be used to provide additional context for the options above.)\" in keq3"
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "preLabel": "KEQ4. What factors limited or prevented (barriers) the successful delivery of outcomes for the investment priority(ies)?",
                "type": "select2Many",
                "rows": 5,
                "source": "keq4"
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "preLabel": "Please specify the other limiting factors and or barriers",
                "type": "textarea",
                "rows": 2,
                "source": "keq4Other"
              }
            ],
            "behaviour": [
              {
                "type": "if_expression",
                "condition": "\"Other (enable mandatory free text to define if ‘other’ selected. ‘Other’ could also be used to provide additional context for the options above.)\" in keq4"
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "preLabel": "KEQ5. Has the project’s risk assessment and risk management remained appropriate and effective throughout the life of the project?",
                "type": "selectOne",
                "rows": 5,
                "source": "keq5"
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "preLabel": "KEQ5.1 Why?",
                "type": "textarea",
                "rows": 5,
                "source": "keq5Why"
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "preLabel": "KEQ6. Did your project engage with traditional owners?",
                "type": "selectOne",
                "rows": 5,
                "source": "keq6"
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "preLabel": "KEQ6.1 If yes, how?  If no, why not?",
                "type": "textarea",
                "rows": 5,
                "source": "keq6How"
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "preLabel": "KEQ7. Have there been any unexpected or unintended (positive or negative) changes or other outcomes delivered by this project?",
                "type": "selectOne",
                "rows": 5,
                "source": "keq7"
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "preLabel": "KEQ7.1 If yes, what are they?",
                "type": "textarea",
                "rows": 5,
                "source": "keq7What"
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "preLabel": "KEQ8. Did this project receive funding and/or in-kind services from any other sources apart from the Australian Government program?",
                "type": "selectOne",
                "rows": 5,
                "source": "keq8"
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "preLabel": "KEQ8.1 If yes, please specify source and the proportion of funding and/or the type and quantity of in-kind services contributed to the project.",
                "type": "textarea",
                "rows": 5,
                "source": "keq8Specify"
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "preLabel": "KEQ9. To what extent has the project achieved the desired behavioural change and ongoing commitment among the participating land managers/owners towards the investment priority?",
                "type": "selectOne",
                "rows": 5,
                "source": "keq9"
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "preLabel": "KEQ9.1 How?",
                "type": "textarea",
                "rows": 5,
                "source": "keq9How"
              }
            ]
          },
          {
            "type": "row",
            "items": [
              {
                "preLabel": "KEQ10. How will the outcomes be maintained beyond the life the project? (refer to project assumptions if applicable)",
                "type": "textarea",
                "rows": 5,
                "source": "keq10"
              }
            ]
          }
        ],
        "pre-populate": [
          {
            "source": {
              "context-path": "owner"
            },
            "merge": {
              "programSecondaryOutcomes": {
                "deleteUnmatchedExistingRows": true,
                "addUnmatchedNewRows": true,
                "keys": [
                  "outcomeStatement"
                ]
              }
            },
            "mapping": [
              {
                "source-path": "custom.details.outcomes.primaryOutcome.description",
                "target": "primaryOutcomeDescription"

              },
              {
                "source-path": "custom.details.outcomes.primaryOutcome.assets",
                "target": "primaryOutcomeInvestmentPriority"

              }
            ]
          },
          {
            "source": {
              "context-path": "owner"
            },
            "merge": {
              "programSecondaryOutcomes": {
                "deleteUnmatchedExistingRows": true,
                "addUnmatchedNewRows": true,
                "keys": [
                  "outcomeStatement"
                ]
              }
            },
            "mapping": [
              {
                "target": "programSecondaryOutcomes",
                "mapping": [
                  {
                    "source-path": "description",
                    "target": "secondaryOutcomeStatement"

                  },
                  {
                    "source-path": "assets",
                    "target": "secondaryOutcomeInvestmentPriorities"
                  }
                ],
                "source-path": "custom.details.outcomes.secondaryOutcomes"
              }
            ]
          },
          {
            "source": {
              "context-path": "owner"
            },
            "merge": {
              "projectOutcomes": {
                "deleteUnmatchedExistingRows": true,
                "addUnmatchedNewRows": true,
                "keys": [
                  "outcomeStatement"
                ]
              }
            },
            "mapping": [
              {
                "target": "projectOutcomes",
                "mapping": [
                  {
                    "target": "code",
                    "source-path": "code"
                  },
                  {
                    "target": "outcomeStatement",
                    "source-path": "description"
                  },
                  {
